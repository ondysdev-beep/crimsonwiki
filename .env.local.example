# FIXED: Added missing environment variables including AdSense slots and import token
# Supabase — found in Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_SITE_URL=https://crimsonwiki.org

# AdSense slot IDs (found in Google AdSense > Ads > By ad unit)
NEXT_PUBLIC_ADSENSE_LEFT_SLOT=
NEXT_PUBLIC_ADSENSE_RIGHT_SLOT=

# Import secret (min 32 chars, generate with: openssl rand -hex 32)
IMPORT_SECRET_TOKEN=

# Optional: Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Bing Webmaster Tools
NEXT_PUBLIC_BING_VERIFICATION=
